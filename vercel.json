{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "redirects": [
    {
      "source": "/cattack",
      "destination": "https://catwar-game.vercel.app",
      "permanent": false
    },
    {
      "source": "/cattack/(.*)",
      "destination": "https://catwar-game.vercel.app/$1",
      "permanent": false
    },
    {
      "source": "/catwar",
      "destination": "https://catwar-game.vercel.app",
      "permanent": false
    },
    {
      "source": "/catwar/(.*)",
      "destination": "https://catwar-game.vercel.app/$1",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/catwar-game/Build/(.*).unityweb",
      "headers": [
        { "key": "Content-Encoding", "value": "br" }
      ]
    },
    {
      "source": "/catwar-game/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/ord-proxy/(.*)",
      "destination": "https://ordinals.com/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://bitcoin-ordinals-backend-production.up.railway.app/api/$1"
    },
    {
      "source": "/palindrom/(.*)",
      "destination": "/palindrom/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
