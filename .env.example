# Backend API URL (Ord-Server / Marketplace)
# Stabiler Public Endpoint:
VITE_INSCRIPTION_API_URL=https://api.richart.app
VITE_ORD_SERVER_URL=https://api.richart.app
# Optional: Marketplace-Bildproxy über api.richart (standardmäßig aus — oft 502)
# VITE_USE_RICHART_IMAGE_PROXY=true

# Optional lokal überschreiben:
# VITE_INSCRIPTION_API_URL=http://localhost:3003
# VITE_ORD_SERVER_URL=https://api.richart.app

